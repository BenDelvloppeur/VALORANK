# ----------------------------------------------------------------------------
# Variables partagées (pour information). Chaque sous-projet a son propre .env
# Voir frontend/.env.example et backend/.env.example pour le détail.
# ----------------------------------------------------------------------------

# Supabase project (https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres (issu de Supabase > Project Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
